# AI Team Office - Environment Configuration
# GitHub Issue #14: Динамическое перемещение агентов

# Application
NODE_ENV=production
PORT=3001

# GitHub API Token (обязательно для получения issues)
# Получить токен: https://github.com/settings/tokens
# Необходимы права: repo (для приватных репозиториев) или public_repo
GITHUB_TOKEN=your_github_token_here

# Database (если понадобится в будущем)
# DATABASE_URL=postgresql://user:pass@localhost:5432/ai_office

# Redis (для кэширования, опционально)
# REDIS_URL=redis://localhost:6379

# Monitoring
HEALTH_CHECK_INTERVAL=60
ALERT_WEBHOOK=

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/ai-team-office/app.log

# Security
# JWT_SECRET=your-secret-key-here
# API_KEY=your-api-key-here
