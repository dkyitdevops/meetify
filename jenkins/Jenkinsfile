pipeline {
    agent any
    
    environment {
        TEST_URL = 'https://46-149-68-9.nip.io'
        ALLURE_RESULTS = 'tests/allure-results'
    }
    
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/dkyitdevops/meetify.git'
            }
        }
        
        stage('Install Dependencies') {
            steps {
                dir('tests') {
                    sh 'npm install'
                }
            }
        }
        
        stage('Run Smoke Tests') {
            steps {
                dir('tests') {
                    sh 'npm run test:allure'
                }
            }
        }
        
        stage('Generate Allure Report') {
            steps {
                allure([
                    includeProperties: false,
                    jdk: '',
                    properties: [],
                    reportBuildPolicy: 'ALWAYS',
                    results: [[path: 'tests/allure-results']]
                ])
            }
        }
        
        stage('Deploy if Tests Pass') {
            when {
                expression { currentBuild.result == null || currentBuild.result == 'SUCCESS' }
            }
            steps {
                sshagent(['deploy-key']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no root@46.149.68.9 "
                            cd /opt/meetify &&
                            git pull origin main &&
                            docker compose up -d --build &&
                            docker compose ps
                        "
                    '''
                }
            }
        }
    }
    
    post {
        always {
            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'tests/allure-report',
                reportFiles: 'index.html',
                reportName: 'Allure Report'
            ])
        }
        failure {
            emailext (
                subject: "Meetify Tests Failed: ${env.JOB_NAME} - ${env.BUILD_NUMBER}",
                body: "Tests failed. Check Allure report: ${env.BUILD_URL}allure",
                to: "${env.CHANGE_AUTHOR_EMAIL}"
            )
        }
    }
}